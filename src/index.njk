<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ home.seo.title }}</title>
    <meta name="description" content="{{ home.seo.description }}" />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles.css?v=home-carousel-16x9" />
  </head>
  <body data-page-type="home" data-page-title="Home">
    <header class="site-header" data-header>
      <a class="brand" href="#home" aria-label="{{ home.brand.name }} home">
        <span class="brand-mark" aria-hidden="true"><img src="{{ home.brand.logo }}" alt="" /></span>
        <span>
          <strong>{{ home.brand.name }}</strong>
          <small>{{ home.brand.tagline }}</small>
        </span>
      </a>
      <button class="nav-toggle" type="button" aria-label="Open navigation" data-nav-toggle>
        <span></span>
        <span></span>
      </button>
      <nav class="main-nav" data-nav>
        <a href="/about.html">About</a>
        <a href="/products.html">Products</a>
        <a href="#capabilities">Capabilities</a>
        <a href="#workflow">Workflow</a>
        <a href="#contact">Contact</a>
        <a class="nav-cta" href="{{ home.nav.send_case_link }}">{{ home.nav.send_case_label }}</a>
      </nav>
    </header>

    <main id="home">
      <section class="hero">
        <div class="hero-carousel" data-hero-carousel>
          <img class="hero-image hero-slide is-active" src="{{ home.hero.image }}" alt="{{ home.hero.image_alt }}" data-hero-eyebrow="{{ home.hero.eyebrow | escape }}" data-hero-title="{{ home.hero.title | escape }}" data-hero-subtitle="{{ home.hero.subtitle | escape }}" />
          {% if home.hero.carousel_images %}
            {% for slide in home.hero.carousel_images %}
              <img class="hero-image hero-slide" src="{{ slide.image }}" alt="{{ slide.image_alt }}" data-hero-eyebrow="{{ slide.eyebrow | escape }}" data-hero-title="{{ slide.title | escape }}" data-hero-subtitle="{{ slide.subtitle | escape }}" aria-hidden="true" />
            {% endfor %}
          {% endif %}
        </div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
          <p class="eyebrow" data-hero-copy-field="eyebrow">{{ home.hero.eyebrow }}</p>
          <h1 data-hero-copy-field="title">{{ home.hero.title }}</h1>
          <p class="hero-copy" data-hero-copy-field="subtitle">{{ home.hero.subtitle }}</p>
          <div class="hero-actions">
            <a class="button button-primary" href="{{ home.hero.primary_button_link }}">{{ home.hero.primary_button_label }}</a>
            <a class="button button-ghost" href="{{ home.hero.secondary_button_link }}">{{ home.hero.secondary_button_label }}</a>
          </div>
          {% if home.hero.metrics %}
            <div class="hero-metrics" aria-label="Company highlights">
              {% for metric in home.hero.metrics %}
                <span><strong>{{ metric.value }}</strong>{{ metric.label }}</span>
              {% endfor %}
            </div>
          {% endif %}
        </div>
        {% if home.hero.carousel_images %}
          <div class="hero-carousel-dots" aria-label="Homepage images">
            <button class="hero-carousel-dot is-active" type="button" data-hero-dot="0" aria-label="Show homepage image 1" aria-current="true"></button>
            {% for slide in home.hero.carousel_images %}
              <button class="hero-carousel-dot" type="button" data-hero-dot="{{ loop.index }}" aria-label="Show homepage image {{ loop.index + 1 }}" aria-current="false"></button>
            {% endfor %}
          </div>
        {% endif %}
      </section>

      {% if home.service_overview %}
        <section class="section intro-strip" aria-label="Service overview">
          {% for item in home.service_overview %}
            <div>
              <span>{{ item.number }}</span>
              <strong>{{ item.title }}</strong>
              <p>{{ item.description }}</p>
            </div>
          {% endfor %}
        </section>
      {% endif %}

      <section class="section split" id="about">
        <div class="section-copy">
          <p class="eyebrow">{{ home.about.eyebrow }}</p>
          <h2>{{ home.about.title }}</h2>
          {% for paragraph in home.about.paragraphs %}
            <p>{{ paragraph }}</p>
          {% endfor %}
          <a class="text-link" href="{{ home.about.button_link }}">{{ home.about.button_label }}</a>
        </div>
        {% if home.about.facts %}
          <div class="about-panel">
            {% for fact in home.about.facts %}
              <div>
                <strong>{{ fact.title }}</strong>
                <span>{{ fact.description }}</span>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </section>

      <section class="section product-section" id="products">
        <div class="section-heading">
          <p class="eyebrow">{{ home.product_section.eyebrow }}</p>
          <h2>{{ home.product_section.title }}</h2>
          <p>{{ home.product_section.description }}</p>
        </div>
        <div class="product-grid">
          {% for product in products %}
            {% if loop.index <= home.product_section.max_items %}
              <a class="product-card" href="{{ product.url }}">
                <img src="{{ product.card_image }}" alt="{{ product.card_alt }}" />
                <div class="product-card-body">
                  <span class="product-icon">{{ product.icon }}</span>
                  <h3>{{ product.title }}</h3>
                  <p>{{ product.short_description }}</p>
                </div>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </section>

      <section class="section capabilities" id="capabilities">
        <div class="section-copy">
          <p class="eyebrow">{{ home.capabilities.eyebrow }}</p>
          <h2>{{ home.capabilities.title }}</h2>
          <p>{{ home.capabilities.description }}</p>
        </div>
        {% if home.capabilities.items %}
          <div class="capability-list">
            {% for item in home.capabilities.items %}
              <div><strong>{{ item.title }}</strong><span>{{ item.description }}</span></div>
            {% endfor %}
          </div>
        {% endif %}
      </section>

      <section class="section workflow" id="workflow">
        <div class="section-heading">
          <p class="eyebrow">{{ home.workflow.eyebrow }}</p>
          <h2>{{ home.workflow.title }}</h2>
        </div>
        {% if home.workflow.steps %}
          <ol class="timeline">
            {% for step in home.workflow.steps %}
              <li>
                <strong>{{ step.title }}</strong>
                <p>{{ step.description }}</p>
              </li>
            {% endfor %}
          </ol>
        {% endif %}
      </section>

      <section class="section quality-band">
        <div>
          <p class="eyebrow">{{ home.quality.eyebrow }}</p>
          <h2>{{ home.quality.title }}</h2>
        </div>
        {% if home.quality.items %}
          <ul>
            {% for item in home.quality.items %}
              <li>{{ item }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      </section>

      <section class="section contact-section" id="contact">
        <div class="section-copy">
          <p class="eyebrow">{{ home.contact.eyebrow }}</p>
          <h2>{{ home.contact.title }}</h2>
          <p>{{ home.contact.description }}</p>
        </div>
        <div class="contact-card">
          <a href="{{ home.contact.phone_link }}"><span>Phone</span>{{ home.contact.phone }}</a>
          <a href="{{ home.contact.email_link }}"><span>Email</span>{{ home.contact.email }}</a>
          <a href="{{ home.contact.whatsapp_link }}"><span>WhatsApp</span>{{ home.contact.whatsapp }}</a>
          <p><span>Address</span>{{ home.contact.address }}</p>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div>
        <strong>{{ home.footer.company_name }}</strong>
        <span>{{ home.footer.company_legal_name }}</span>
      </div>
      <nav aria-label="Footer navigation">
        <a href="/about.html">About</a>
        <a href="/products.html">Products</a>
        <a href="#workflow">Workflow</a>
        <a href="#contact">Contact</a>
      </nav>
      <p>{{ home.footer.copyright }}</p>
    </footer>

    <script src="/script.js?v=home-carousel-16x9"></script>
  </body>
</html>
